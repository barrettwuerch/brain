{
  "mode": "paper",
  "baseUrl": "https://api.elections.kalshi.com",
  "pollIntervalMs": 5000,
  "orderbookDepth": 1,

  "citiesPath": "/Users/bear/.openclaw/workspace/projects/kalshi/weather/cities.json",

  "marketSelection": {
    "maxCities": 5,
