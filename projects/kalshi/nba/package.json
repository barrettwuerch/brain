{
  "name": "kalshi-nba-bot",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "Kalshi NBA live probability mean reversion bot (paper/shadow v0)",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/nba_bot.mjs --config config.paper.json",
    "run": "node src/nba_bot.mjs",
    "dashboard": "node src/dashboard_server.mjs",
    "pull:historical": "node scripts/pull_historical.mjs",
    "score": "node src/score_cli.mjs",
    "scorer:calibrate": "node scripts/calibrate_scorer.mjs --dir ./data_full",
    "reviewer:test": "node scripts/test_reviewer.mjs --dir ./data_full",
    "sim:replay": "node scripts/sim_replay.mjs",
    "backtest": "node scripts/backtest_50k.mjs --dir ./data_full",
    "hist:summary": "node scripts/hist_summary.mjs --dir ./data_full",
    "hist:exitopt": "node scripts/exit_optimize.mjs --dir ./data_full",
    "hist:exitgrid": "node scripts/exit_grid.mjs --dir ./data_full --q4cap true",
    "hist:q4cut": "node scripts/exit_q4_cutoffs.mjs --dir ./data_full",
    "hist:prod-ev": "node scripts/exit_prod_ev.mjs --dir ./data_full",
    "hist:audit": "node scripts/hist_audit.mjs --dir ./data_full",
    "hist:oos": "node scripts/hist_oos.mjs --dir ./data_full",
    "lint": "node src/health.mjs"
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
