# THE BRAIN — env

# Test mode (no-LLM mode): when true, reason()/reflect() are deterministic stubs and embed() returns seeded vectors.
BRAIN_TEST_MODE=true

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LLMs
ANTHROPIC_API_KEY=your-claude-key
OPENAI_API_KEY=your-openai-key

# Embeddings
# Choose provider/model in code; keep key in OPENAI_API_KEY for Phase 1.
