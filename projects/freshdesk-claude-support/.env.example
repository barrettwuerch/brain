# Run without real keys (placeholders/stubs)
USE_STUBS=true

# --- Freshdesk (Tickets + Email) ---
# Accepts either "yourcompany" or "yourcompany.freshdesk.com"
FRESHDESK_DOMAIN=yourcompany
FRESHDESK_API_KEY=__replace__
# Webhook verification (MVP). Configure same secret in Freshdesk webhook header X-Webhook-Secret.
FRESHDESK_WEBHOOK_SECRET=__replace__

# --- Freshchat (Live Chat) ---
FRESHCHAT_API_URL=https://yourcompany.freshchat.com/v2
FRESHCHAT_API_KEY=__replace__
FRESHCHAT_BOT_AGENT_ID=__replace__
FRESHCHAT_ESCALATION_AGENT_ID=__replace__

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=__replace__
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# --- Admin Portal (Plaid / Transactions) ---
ADMIN_PORTAL_BASE_URL=https://admin.example.com
ADMIN_PORTAL_API_KEY=__replace__

# Optional: RAG
RAG_PROVIDER=none  # none|pgvector
PGVECTOR_URL=postgres://postgres:postgres@localhost:5432/support

# App
PORT=8787
PUBLIC_BASE_URL=http://localhost:8787
LOG_LEVEL=info

# Safety / policy knobs
REFUND_APPROVAL_THRESHOLD_USD=50
MAX_TOOL_CALLS_PER_TURN=6
MAX_TOKENS_PER_TICKET=18000
