{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MarketLensInsight",
  "type": "object",
  "required": ["id", "created_at", "headline", "thesis", "direction", "conviction", "time_horizon", "sources"],
  "properties": {
    "id": {"type": "string", "description": "Stable id (uuid)"},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},

    "headline": {"type": "string"},
    "thesis": {"type": "string", "description": "1-line plain English thesis"},
    "details": {"type": "string", "description": "Expanded thesis"},

    "direction": {"type": "string", "enum": ["bullish", "bearish", "mixed", "unclear"]},
    "conviction": {"type": "integer", "minimum": 1, "maximum": 5},
    "time_horizon": {"type": "string", "enum": ["days", "weeks", "months", "quarters", "years"]},

    "category": {"type": "string", "enum": ["legal", "regulatory", "earnings", "macro", "geopolitical", "sector", "sentiment", "other"]},
    "tickers": {"type": "array", "items": {"type": "string"}},
    "sectors": {"type": "array", "items": {"type": "string"}},

    "second_order_effects": {"type": "array", "items": {"type": "string"}},
    "risks": {"type": "array", "items": {"type": "string"}},

    "pipeline": {
      "type": "object",
      "description": "For pipeline news (court/regulatory/legislative) that is not yet market-moving",
      "properties": {
        "is_pipeline": {"type": "boolean"},
        "next_milestone": {"type": "string"},
        "probability": {"type": "number", "minimum": 0, "maximum": 1},
        "estimated_timeline": {"type": "string"}
      },
      "additionalProperties": false
    },

    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url", "source", "published_at"],
        "properties": {
          "url": {"type": "string"},
          "source": {"type": "string"},
          "published_at": {"type": "string", "format": "date-time"},
          "title": {"type": "string"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
